# Ignore examples directory
examples/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.mypy_cache/
.pytest_cache/
.ruff_cache/
.venv/
venv/
# Isolated build-only venvs created by server/packaging/build.ps1 so a
# release build never touches the dev .venv (which is held open by the
# live stt-server.exe whenever bun electron:dev is running).
.venv-build-*/
.coverage
*.egg-info/
dist/
build/

# Node/Bun
node_modules/
.next/
out/
.turbo/
bun.lockb

# Electron
dist-electron/
release/
*.exe
*.dmg
*.AppImage

# Tiny native paste/context helpers (~150 KB each) shipped prebuilt so a
# fresh checkout doesn't need MSVC just to run `bun electron:dev`. Rebuild
# from source via `bun --cwd frontend run native:build` if you modify the
# .c sources alongside.
!frontend/electron/native/bin/winstt-paste.exe
!frontend/electron/native/bin/winstt-context.exe

# Packaged STT server bundles — produced by server/packaging/build.ps1
# from a PyInstaller spec. Each is multi-GB (especially the GPU flavor)
# and rebuilt fresh per release tag. cpu/ and gpu/ live under
# packaging/stt-server-dist/, which the root electron-builder.*.yml
# read via ``extraResources``.
packaging/stt-server-dist/

# Vendored offline base model (whisper-tiny q4) — downloaded at build
# time by server/packaging/seed_models.py, bundled into the exe, never
# committed (tens of MB, reproducible from the HF hub).
server/packaging/seed-cache/

# On-demand TTS support pack — produced by server/packaging/build_tts_pack.py
# and uploaded to the GitHub Release, never committed (~29 MB, reproducible).
server/packaging/dist-tts/

# Environment
.env
.env.local
.env*.local

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
debug.log
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
*.tmp
*.tmp.*
*.temp
*.bak
~*

# Trace / profiling output
trace.err
trace.out
.profile/

# Local analysis & mutation testing artifacts
crap-*.json
frontend/reports/crap-*.json
frontend/reports/mutation/
# Server CRAP outputs: coverage JSON (refreshed by pytest) + crap.json
# (the analyzer's per-function report). Both are reproducible from a
# pytest run; never committed.
server/reports/
test-skip.test.ts

# Local agent skill installs (machine-specific)
.claude/skills/
.agents/skills/
skills-lock.json

# Docs build output (Nitro/Fumadocs)
docs/.output/

# Scratch
frontend/scripts/wip.txt
frontend/.rd-*.txt
frontend/.react-doctor-*.txt
.rd-*.txt
.claude/scheduled_tasks.lock

# Minisign keys — used to sign release artifacts (see docs/RELEASE_SIGNING.md).
# Secret keys (.key) MUST NEVER be committed. Public keys (.pub) are safe to
# commit and are checked into docs/winstt.pub. The negative pattern below
# preserves any *.pub already tracked by git.
*.key
!*.pub
