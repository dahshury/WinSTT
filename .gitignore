artifacts/

# Python tooling cache (ruff) — stray ephemeral cache, never commit
.ruff_cache/

# TTS engine-spike model cache (kitten/piper/supertonic/chatterbox/oute weights,
# loaded by src-tauri/examples/tts_engine_spike.rs). Re-downloadable; never commit.
.tts-cache/

