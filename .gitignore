# Ignore examples directory
examples/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.mypy_cache/
.pytest_cache/
.ruff_cache/
.venv/
venv/
.coverage
*.egg-info/
dist/
build/

# Node/Bun
node_modules/
.next/
out/
.turbo/
bun.lockb

# Electron
dist-electron/
release/
*.exe
*.dmg
*.AppImage

# Packaged STT server bundles — produced by server/packaging/build.ps1
# from a PyInstaller spec. Each is multi-GB (especially the GPU flavor)
# and rebuilt fresh per release tag.
stt-server-dist/
stt-server-dist-cpu/
stt-server-dist-gpu/

# Vendored offline base model (whisper-tiny q4) — downloaded at build
# time by server/packaging/seed_models.py, bundled into the exe, never
# committed (tens of MB, reproducible from the HF hub).
server/packaging/seed-cache/

# On-demand TTS support pack — produced by server/packaging/build_tts_pack.py
# and uploaded to the GitHub Release, never committed (~29 MB, reproducible).
server/packaging/dist-tts/

# Environment
.env
.env.local
.env*.local

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
debug.log
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
*.tmp
*.tmp.*
*.temp
*.bak
~*

# Trace / profiling output
trace.err
trace.out
.profile/

# Local analysis & mutation testing artifacts
crap-*.json
frontend/reports/crap-*.json
