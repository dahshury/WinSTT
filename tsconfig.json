{
  "compilerOptions": {
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,

    /* Path Aliases — renderer (@/*) + Tauri bindings (@/bindings).
       No `baseUrl` (removed in TS 7 / tsgo): non-relative `paths` mappings
       resolve relative to this tsconfig's directory, so the explicit `./`
       prefixes below are self-anchored. */
    "paths": {
      "@/bindings": ["./src/bindings.ts"],
      "@/*": ["./src/*"],
      "@test/*": ["./test/*"]
    },

    /* Strictness — maximum type-soundness gate. Every type-checking
       strictness lever TypeScript/tsgo exposes is on; the only ones left
       off are emit-shape constraints (isolatedDeclarations) irrelevant to
       this `noEmit` renderer. */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitReturns": true,
    "noPropertyAccessFromIndexSignature": true,
    "noUncheckedSideEffectImports": true,
    "allowUnreachableCode": false,
    "allowUnusedLabels": false
  },
  "include": ["src", "spec"],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.property.test.ts",
    "**/*.property.test.tsx",
    "**/*test-helpers*",
    "**/__tests__/**"
  ]
}
