{
	"name": "winstt-app",
	"private": true,
	"version": "0.1.3-alpha.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"lint": "eslint src packages/model-picker/src",
		"lint:fix": "eslint src packages/model-picker/src --fix",
		"format": "prettier --write . && cd src-tauri && cargo fmt",
		"format:check": "prettier --check . && cd src-tauri && cargo fmt -- --check",
		"format:frontend": "prettier --write .",
		"format:backend": "cd src-tauri && cargo fmt",
		"typecheck": "bun node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
		"check:i18n": "bun tools/i18n/check-i18n.ts",
		"check:i18n:strict": "bun tools/i18n/check-i18n.ts --strict",
		"check:translations": "bun tools/i18n/check-i18n.ts",
		"postinstall": "bun tools/check-nix-deps.ts",
		"test": "bun run test:src:entries && bun run test:src:app && bun run test:src:entities && bun run test:src:features && bun run test:src:shared && bun run test:src:views && bun run test:src:widgets && bun run test:packages",
		"test:src": "bun test ./src",
		"test:src:entries": "bun test ./src/entries",
		"test:src:app": "bun test ./src/app",
		"test:src:entities": "bun test ./src/entities",
		"test:src:features": "bun test ./src/features",
		"test:src:shared": "bun test ./src/shared",
		"test:src:views": "bun test ./src/views",
		"test:src:widgets": "bun test ./src/widgets",
		"test:entities": "bun run test:src:entities",
		"test:features": "bun run test:src:features",
		"test:shared": "bun run test:src:shared",
		"test:views": "bun run test:src:views",
		"test:widgets": "bun run test:src:widgets",
		"test:packages": "bun test ./packages",
		"test:coverage": "bun test ./src ./packages --coverage",
		"check:deadcode": "knip",
		"check:deadcode:files": "knip --files",
		"check:deadcode:deps": "knip --dependencies",
		"check:deadcode:exports": "knip --exports",
		"check:cleanup": "bun run lint && bun run typecheck && bun run check:deadcode",
		"docs:dev": "cd docs && bun run dev",
		"docs:build": "cd docs && bun run build",
		"docs:build:pages": "cd docs && bun run build:pages",
		"docs:videos": "cd tools/remotion-demos && npm run render:all"
	},
	"dependencies": {
		"@base-ui/react": "^1.4.1",
		"@hugeicons/core-free-icons": "^4.1.2",
		"@hugeicons/react": "^1.1.6",
		"@tailwindcss/vite": "^4.1.16",
		"@tanstack/react-table": "^8.21.3",
		"@tauri-apps/api": "^2.11.0",
		"@tauri-apps/plugin-autostart": "~2.5.1",
		"@tauri-apps/plugin-clipboard-manager": "~2.3.2",
		"@tauri-apps/plugin-dialog": "~2.7.1",
		"@tauri-apps/plugin-opener": "^2.5.4",
		"@tauri-apps/plugin-os": "~2.3.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"double-metaphone": "^2.0.0",
		"fuse.js": "^7.0.0",
		"motion": "^12.38.0",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.1.16",
		"use-intl": "^4.12.0",
		"virtua": "^0.49.1",
		"zod": "^4.4.3",
		"zustand": "^5.0.13"
	},
	"devDependencies": {
		"@happy-dom/global-registrator": "^20.9.0",
		"@rolldown/plugin-babel": "^0.2.3",
		"@tauri-apps/cli": "^2.11.2",
		"@testing-library/react": "^16.3.2",
		"@types/bun": "latest",
		"@types/node": "^24.9.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.49.0",
		"@typescript-eslint/parser": "^8.49.0",
		"@vitejs/plugin-react": "^6.0.0",
		"babel-plugin-react-compiler": "^1.0.0",
		"eslint": "^9.39.1",
		"eslint-plugin-i18next": "^6.1.3",
		"fast-check": "^4.8.0",
		"knip": "^5.64.4",
		"prettier": "^3.6.2",
		"rollup-plugin-visualizer": "^6.0.4",
		"typescript": "~5.9.0",
		"vite": "^8.0.0"
	},
	"overrides": {
		"@tauri-apps/api": "2.11.0"
	}
}
