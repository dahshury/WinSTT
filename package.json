{
	"name": "winstt-app",
	"private": true,
	"version": "0.1.3-alpha.3",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "bun run typecheck && vite build",
		"preview": "vite preview",
		"tauri": "tauri",
		"lint": "eslint src",
		"lint:fix": "eslint src --fix",
		"format": "prettier --write . && cd src-tauri && cargo fmt",
		"format:check": "prettier --check . && cd src-tauri && cargo fmt -- --check",
		"format:frontend": "prettier --write .",
		"format:backend": "cd src-tauri && cargo fmt",
		"typecheck": "bun run typecheck:app && bun run typecheck:node",
		"typecheck:all": "bun run typecheck:app && bun run typecheck:tests && bun run typecheck:node && cd docs && bun run types:check && cd ../tools/remotion-demos && bun run types:check",
		"typecheck:app": "tsgo -p tsconfig.json --noEmit",
		"typecheck:tests": "tsgo -p tsconfig.all.json --noEmit",
		"typecheck:node": "tsgo -p tsconfig.node.json --noEmit",
		"check:i18n": "bun tools/i18n/check-i18n.ts",
		"check:i18n:strict": "bun tools/i18n/check-i18n.ts --strict",
		"check:translations": "bun tools/i18n/check-i18n.ts",
		"postinstall": "bun tools/check-nix-deps.ts",
		"test": "bun run test:src:entries && bun run test:src:app && bun run test:src:entities && bun run test:src:features && bun run test:src:shared && bun run test:src:views && bun run test:src:widgets",
		"test:src": "bun test ./src",
		"test:src:entries": "bun test ./src/entries",
		"test:src:app": "bun test ./src/app",
		"test:src:entities": "bun test ./src/entities",
		"test:src:features": "bun test ./src/features",
		"test:src:shared": "bun test ./src/shared",
		"test:src:views": "bun test ./src/views",
		"test:src:widgets": "bun test ./src/widgets",
		"test:entities": "bun run test:src:entities",
		"test:features": "bun run test:src:features",
		"test:shared": "bun run test:src:shared",
		"test:views": "bun run test:src:views",
		"test:widgets": "bun run test:src:widgets",
		"test:coverage": "bun test ./src --coverage",
		"test:a11y": "playwright test --config=playwright.a11y.config.ts",
		"check:deadcode": "knip",
		"check:deadcode:files": "knip --files",
		"check:deadcode:deps": "knip --dependencies",
		"check:deadcode:exports": "knip --exports",
		"check:cleanup": "bun run lint && bun run typecheck && bun run check:deadcode",
		"docs:dev": "cd docs && bun run dev",
		"docs:build": "cd docs && bun run build",
		"docs:build:pages": "cd docs && bun run build:pages",
		"docs:videos": "cd tools/remotion-demos && npm run render:all",
		"tools:chrome-login": "node tools/chrome-cdp-show-login.mjs",
		"tools:context-cdp": "node tools/context-cdp-capture.mjs"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/modifiers": "^9.0.0",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@hugeicons/core-free-icons": "^4.2.1",
		"@hugeicons/react": "^1.1.7",
		"@tailwindcss/vite": "^4.3.1",
		"@tanstack/react-table": "^8.21.3",
		"@tanstack/react-virtual": "^3.14.3",
		"@tauri-apps/api": "^2.11.1",
		"@tauri-apps/plugin-autostart": "~2.5.1",
		"@tauri-apps/plugin-clipboard-manager": "~2.3.2",
		"@tauri-apps/plugin-dialog": "~2.7.1",
		"@tauri-apps/plugin-opener": "^2.5.4",
		"@tauri-apps/plugin-os": "~2.3.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"double-metaphone": "^2.0.1",
		"motion": "^12.40.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.1",
		"use-intl": "^4.13.0",
		"virtua": "^0.49.1",
		"zod": "^4.4.3",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@axe-core/playwright": "^4.11.3",
		"@happy-dom/global-registrator": "^20.10.6",
		"@playwright/test": "1.61.0",
		"@rolldown/plugin-babel": "^0.2.3",
		"@tauri-apps/cli": "^2.11.3",
		"@testing-library/react": "^16.3.2",
		"@types/bun": "latest",
		"@types/node": "^24.13.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@typescript-eslint/eslint-plugin": "^8.62.0",
		"@typescript-eslint/parser": "^8.62.0",
		"@typescript/native-preview": "^7.0.0-dev.20260622.1",
		"@vitejs/plugin-react": "^6.0.2",
		"axe-core": "^4.11.4",
		"babel-plugin-react-compiler": "^1.0.0",
		"eslint": "^9.39.4",
		"eslint-plugin-i18next": "^6.1.4",
		"fast-check": "^4.8.0",
		"knip": "^5.88.1",
		"prettier": "^3.8.4",
		"rollup-plugin-visualizer": "^6.0.11",
		"typescript": "~5.9.3",
		"vite": "^8.0.16",
		"ws": "^8.21.0"
	},
	"overrides": {
		"@tauri-apps/api": "2.11.1"
	}
}
