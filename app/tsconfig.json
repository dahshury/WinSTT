{
  "compilerOptions": {
    "target": "ES2023",
    "useDefineForClassFields": true,
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "forceConsistentCasingInFileNames": true,

    /* Path Aliases — renderer (@/*, @spec/*, @picker) + Tauri bindings (@/bindings) */
    "baseUrl": ".",
    "paths": {
      "@/bindings": ["./src/bindings.ts"],
      "@/*": ["./src/*"],
      "@spec/*": ["./spec/generated/ts/*"],
      "@picker": ["./packages/model-picker/src/index.ts"],
      "@picker/*": ["./packages/model-picker/src/*"]
    },

    /* Linting (matched to WinSTT's renderer tsconfig) */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "exactOptionalPropertyTypes": true
  },
  "include": ["src", "packages", "spec"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
