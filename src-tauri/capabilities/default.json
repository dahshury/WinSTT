{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Shared renderer baseline. Keep this small: every WinSTT window inherits it.",
  "windows": [
    "main",
    "splash",
    "settings",
    "overlay",
    "tray-menu",
    "model-picker",
    "device-picker",
    "model-footprint",
    "onboarding",
    "history",
    "context-playground"
  ],
  "permissions": [
    "core:default",
    "os:allow-locale"
  ]
}
