{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "index.html",
    "windows/*.html",
    "src/entries/*.{ts,tsx}",
    "src/**/*.{test,spec}.{ts,tsx}",
    "tools/**/*.ts",
    "test/**/*.ts",
    "src/widgets/model-picker/index.ts"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "ignoreIssues": {
    "src/widgets/ollama-model-manager/lib/ollama-model-manager-test-helpers.ts": ["exports"],
    "src/bindings.ts": ["exports", "types"],
    "src/shared/api/schema.zod.ts": ["exports", "types"]
  }
}
