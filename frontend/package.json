{
  "name": "winstt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "generate": "openapi-typescript ../spec/openapi.yaml -o src/shared/api/schema.d.ts",
    "knip": "knip",
    "icon:generate": "bun run scripts/generate-placeholder-icon.ts",
    "electron:compile:main": "tsup electron/main.ts --format esm --outDir dist-electron --external electron --external uiohook-napi --clean --sourcemap",
    "electron:compile:preload": "tsup electron/preload.ts --format cjs --outDir dist-electron --external electron --sourcemap",
    "electron:compile": "bun run electron:compile:main && bun run electron:compile:preload",
    "electron:dev": "bun run electron:compile && electron .",
    "electron:build": "bun run build && bun run electron:compile && electron-builder"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@hookform/resolvers": "^5.2.2",
    "@hugeicons/core-free-icons": "^1.0.0",
    "@hugeicons/react": "^1.0.0",
    "clsx": "^2.1.1",
    "geist": "^1.7.0",
    "next": "^16.0.0",
    "next-intl": "^4.8.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.1",
    "tailwind-merge": "^2.6.0",
    "uiohook-napi": "^1.5.4",
    "ws": "^8.19.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@happy-dom/global-registrator": "^20.5.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/styletron-engine-atomic": "^1.1.4",
    "@types/styletron-react": "^5.0.8",
    "@types/styletron-standard": "^2.0.6",
    "@types/ws": "^8.18.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "electron-store": "^10.0.0",
    "happy-dom": "^15.11.0",
    "knip": "^5.38.0",
    "openapi-typescript": "^7.4.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "ultracite": "latest"
  },
  "trustedDependencies": [
    "uiohook-napi"
  ]
}
