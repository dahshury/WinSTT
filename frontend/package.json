{
  "name": "winstt",
  "version": "0.1.0-alpha.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "bun run electron:dev",
    "dev:renderer": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc --noEmit",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "lint:biome": "biome check .",
    "format": "biome format --write .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "bunx playwright install chromium",
    "test:e2e:electron": "bun run electron:compile && PW_SKIP_WEBSERVER=1 playwright test --project=electron",
    "test:visual": "playwright test visual-regression",
    "test:visual:update": "playwright test visual-regression --update-snapshots",
    "generate": "openapi-typescript ../spec/openapi.yaml -o ../spec/generated/ts/schema.d.ts && bun run scripts/generate-zod-schemas.ts && bun run scripts/generate-cloud-models.ts",
    "knip": "knip",
    "icon:generate": "python scripts/generate-icons.py",
    "icon:tray:generate": "python scripts/generate-icons.py",
    "check:fsd": "bun run scripts/check-fsd-violations.ts",
    "check:fsd:diff": "bun run scripts/check-fsd-violations.ts --diff-base origin/main",
    "check:react-doctor": "react-doctor --fail-on error --offline",
    "check:i18n": "bun run scripts/verify-i18n.ts",
    "check:i18n:strict": "bun run scripts/verify-i18n.ts --strict",
    "check:i18n:lint-jsx": "bun run scripts/verify-i18n.ts --lint-jsx",
    "check:ws-contract": "bun run scripts/check-ws-contract.ts",
    "check:casts": "bun run scripts/check-cast-budget.ts",
    "crap:gate": "bun run scripts/crap-gate.ts reports/crap-baseline.json reports/crap.json",
    "coverage:gate": "bun run scripts/coverage-gate.ts",
    "native:build": "node scripts/native/build-winstt-paste.cjs && node scripts/native/build-winstt-context.cjs && node scripts/native/build-winstt-ocr.cjs",
    "splash:generate": "node scripts/generate-splash-bmp.cjs",
    "electron:compile:main": "tsup --config tsup.config.ts",
    "electron:compile": "rm -rf dist-electron && bun run electron:compile:main",
    "electron:watch:main": "tsup --config tsup.config.ts --watch electron --watch src",
    "electron:start": "wait-on tcp:3000 file:dist-electron/main.js file:dist-electron/preload.cjs && bun run scripts/dev-electron.ts",
    "electron:rebuild": "electron-rebuild -o uiohook-napi",
    "electron:rebuild:force": "electron-rebuild -f -o uiohook-napi",
    "electron:dev": "concurrently -k --success first -n vite,main,app -c blue,green,magenta \"bun run dev:renderer\" \"bun run electron:watch:main\" \"bun run electron:start\"",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@ai-sdk/elevenlabs": "^2.0.33",
    "@ai-sdk/openai": "^3.0.65",
    "@base-ui/react": "^1.4.1",
    "@hugeicons/core-free-icons": "^4.1.2",
    "@hugeicons/react": "^1.1.6",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@sentry/electron": "^7.13.0",
    "adm-zip": "^0.5.17",
    "ai": "^6.0.176",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "double-metaphone": "^2.0.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "motion": "^12.38.0",
    "pngjs": "^7.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.5.0",
    "tar": "^7.5.0",
    "uiohook-napi": "^1.5.5",
    "use-intl": "^4.12.0",
    "virtua": "^0.49.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@electron/rebuild": "^4.0.4",
    "@happy-dom/global-registrator": "^20.9.0",
    "@playwright/test": "^1.59.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@stryker-mutator/core": "^9.6.1",
    "@tailwindcss/vite": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/adm-zip": "^0.5.8",
    "@types/bun": "latest",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260508.1",
    "@vitejs/plugin-react": "^6",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^10",
    "electron": "^42.0.0",
    "electron-store": "^11.0.2",
    "fast-check": "^4.8.0",
    "knip": "^6.12.1",
    "openapi-typescript": "^7.13.0",
    "react-doctor": "^0.2.9",
    "tailwindcss": "^4.2.4",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "ultracite": "^7.8.0",
    "vite": "^8",
    "wait-on": "^9.0.5"
  },
  "trustedDependencies": [
    "electron",
    "uiohook-napi"
  ],
  "overrides": {
    "yallist": "^4.0.0"
  }
}
