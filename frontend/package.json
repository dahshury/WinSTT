{
  "name": "winstt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "generate": "openapi-typescript ../spec/openapi.yaml -o ../spec/generated/ts/schema.d.ts",
    "knip": "knip",
    "icon:generate": "bun run scripts/generate-placeholder-icon.ts",
    "check:fsd": "bun run scripts/check-fsd-violations.ts",
    "check:fsd:diff": "bun run scripts/check-fsd-violations.ts --diff-base origin/main",
    "check:i18n": "bun run scripts/verify-i18n.ts",
    "check:i18n:strict": "bun run scripts/verify-i18n.ts --strict",
    "next:prepare-standalone": "node scripts/prepare-next-standalone.mjs",
    "electron:compile:main": "tsup electron/main.ts --format esm --outDir dist-electron --external electron --external uiohook-napi --external pngjs --clean --sourcemap",
    "electron:compile:preload": "tsup electron/preload.ts --format cjs --outDir dist-electron --external electron --sourcemap",
    "electron:compile": "bun run electron:compile:main && bun run electron:compile:preload",
    "electron:rebuild": "electron-rebuild -w uiohook-napi",
    "electron:rebuild:force": "electron-rebuild -f -w uiohook-napi",
    "electron:dev": "bun run electron:compile && bun run electron:rebuild && electron .",
    "electron:build": "bun run build && bun run next:prepare-standalone && bun run electron:compile && bun run electron:rebuild:force && electron-builder",
    "electron:build:publish": "bun run build && bun run next:prepare-standalone && bun run electron:compile && bun run electron:rebuild:force && electron-builder --publish always",
    "postinstall": "bun run electron:rebuild:force"
  },
  "dependencies": {
    "@base-ui/react": "^1.1.0",
    "@hookform/resolvers": "^5.2.2",
    "@hugeicons/core-free-icons": "^1.0.0",
    "@hugeicons/react": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.6.2",
    "geist": "^1.7.0",
    "motion": "^12.35.0",
    "next": "^16.2.6",
    "next-intl": "^4.8.2",
    "pngjs": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.1",
    "tailwind-merge": "^2.6.0",
    "uiohook-napi": "^1.5.4",
    "ws": "^8.19.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.14",
    "@electron/rebuild": "^3.6.1",
    "@happy-dom/global-registrator": "^20.5.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/react": "^16.1.0",
    "@types/bun": "latest",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.0",
    "electron-store": "^10.0.0",
    "knip": "^5.38.0",
    "openapi-typescript": "^7.4.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0",
    "ultracite": "latest"
  },
  "trustedDependencies": [
    "electron",
    "uiohook-napi"
  ]
}
