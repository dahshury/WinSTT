{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "app/**/*.{ts,tsx}",
    "src/**/*.{ts,tsx}",
    "electron/**/*.ts",
    "test/**/*.{ts,tsx}",
    "**/*.test.{ts,tsx}",
