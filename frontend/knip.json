{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "index.html",
    "windows/*.html",
    "src/entries/*.tsx",
    "**/*.test.{ts,tsx}",
    "stryker.conf.json",
    "scripts/**/*.ts"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "electron/**/*.ts",
    "test/**/*.{ts,tsx}",
    "packages/*/src/**/*.{ts,tsx}",
    "scripts/**/*.ts"
  ],
  "ignoreDependencies": [
    "tailwindcss",
    "@stryker-mutator/core",
    "@stryker-mutator/command-runner"
  ]
}
