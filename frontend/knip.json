{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "app/**/*.{ts,tsx}",
    "src/**/*.{ts,tsx}",
    "electron/**/*.ts",
    "test/**/*.{ts,tsx}",
    "**/*.test.{ts,tsx}"
  ],
  "project": [
    "app/**/*.{ts,tsx}",
    "src/**/*.{ts,tsx}",
    "electron/**/*.ts",
    "test/**/*.{ts,tsx}"
  ],
  "ignore": ["spec/**/*"],
  "ignoreDependencies": ["tailwindcss", "postcss", "electron-updater"]
}
