# dependencies (bun install)
node_modules

# output
dist
dist-electron
dist-renderer
*.tgz

# code coverage
coverage
*.lcov

# logs
logs
_.log
report.[0-9]_.[0-9]_.[0-9]_.[0-9]_.json

# electron-log rotation artefact (debug.old.log) — debug.log is matched by *.log
debug.log
debug.old.log

# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# caches
.eslintcache
.cache
*.tsbuildinfo

# IntelliJ based IDEs
.idea

# Finder (MacOS) folder config
.DS_Store

# FSD violation reports (auto-generated by scripts/check-fsd-violations.ts)
docs/violations/
fsd-violations.json

# Playwright
/playwright-report/
/test-results/
/playwright/.cache/

# Stryker mutation testing scratch space (regenerated each run)
.stryker-tmp/

# Design-system extraction artifacts from `npx extract-design-system`.
# Kept locally as reference (raw + normalized + starter tokens); not imported
# into the app — globals.css is the source of truth.
.extract-design-system/
design-system/
.fsd-ledger/
.fsd-fixtures-tmp/

# Windows reserved-device-name files (e.g. a stray `nul` from a botched
# `> nul` redirect under bash/bun). Tailwind v4 auto-source-detection
# respects .gitignore, so ignoring it stops the Turbopack PostCSS panic
# ("reading file frontend\nul" / os error 1) regardless of what creates it.
/nul
/NUL
/aux
/con
/prn
