{
  "$schema": "https://www.react.doctor/schema/react-doctor.json",
  "ignore": {
    "rules": [
      "deslop/unused-file",
      "deslop/unused-dev-dependency",
      "react-doctor/only-export-components",
      "react-hooks-js/incompatible-library",
      "react-hooks-js/todo"
    ],
    "files": [
      "scripts/**",
      "e2e/**",
      "tests/visual/**",
      "dist-renderer/**",
      "dist-electron/**"
    ],
    "overrides": [
      {
        "files": ["**/*.test.ts", "**/*.test.tsx"],
        "rules": [
          "react-doctor/nextjs-no-img-element",
          "react-doctor/async-await-in-loop",
          "react-doctor/no-barrel-import",
          "react-doctor/no-multi-comp",
          "react-doctor/no-giant-component",
          "react-doctor/jsx-no-constructed-context-values",
          "react-doctor/no-render-in-render",
          "react-doctor/no-derived-state",
          "react-doctor/no-derived-state-effect",
          "react-doctor/no-adjust-state-on-prop-change",
          "react-doctor/no-event-handler",
          "react-doctor/no-cascading-set-state",
          "react-doctor/no-chain-state-updates",
          "react-doctor/no-pass-data-to-parent",
          "react-doctor/no-prop-callback-in-effect",
          "react-doctor/exhaustive-deps",
          "react-doctor/control-has-associated-label",
          "react-doctor/prefer-tag-over-role",
          "react-doctor/rerender-state-only-in-handlers",
          "react-doctor/no-initialize-state",
          "react-doctor/rerender-memo-with-default-value",
          "react-doctor/no-array-index-as-key",
          "react-doctor/no-tiny-text",
          "react-doctor/no-react19-deprecated-apis",
          "react-doctor/prefer-useReducer",
          "react-doctor/no-generic-handler-names",
          "react-doctor/no-many-boolean-props",
          "react-doctor/no-reset-all-state-on-prop-change",
          "react-doctor/no-static-element-interactions",
          "react-doctor/click-events-have-key-events",
          "react-doctor/media-has-caption",
          "react-doctor/async-defer-await",
          "react-doctor/design-no-redundant-padding-axes",
          "react-doctor/design-no-redundant-size-axes",
          "react-doctor/use-lazy-motion",
          "react-doctor/rendering-hydration-no-flicker",
          "react-doctor/react-compiler-no-manual-memoization",
          "react-hooks-js/refs",
          "react-hooks-js/set-state-in-effect",
          "react-hooks-js/preserve-manual-memoization",
          "react-hooks-js/purity"
        ]
      },
      {
        "files": ["**/*-test-helpers.{ts,tsx}", "**/*.property.test.{ts,tsx}"],
        "rules": [
          "react-doctor/no-multi-comp",
          "react-doctor/no-giant-component",
          "react-doctor/react-compiler-no-manual-memoization",
          "react-doctor/jsx-no-constructed-context-values",
          "react-hooks-js/refs"
        ]
      }
    ]
  }
}
